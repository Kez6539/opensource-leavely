# Copy this file to .env.local (or .dev.vars for Cloudflare Workers) and fill in
# your own values. NEVER commit real secrets — .env* is gitignored.

# --- App ---
APP_NAME="Leavely OSS"
APP_URL="http://localhost:3000"

# --- Database (required) ---
# Any PostgreSQL instance works. Local example:
DATABASE_URL="postgresql://username:password@localhost:5432/leavely_oss"
# Neon (serverless Postgres) example:
# DATABASE_URL="postgresql://user:password@ep-example-region.aws.neon.tech/leavely_oss?sslmode=require"

# --- Auth (required) ---
# iron-session cookie password. Use any random 32+ character string.
SESSION_PASSWORD="replace_with_a_random_local_secret_at_least_32_chars"

# --- Optional: email (Resend) ---
# RESEND_API_KEY="your_resend_api_key_here"

# --- Optional: payments (Stripe) ---
# STRIPE_SECRET_KEY="your_stripe_secret_key_here"
# STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret_here"

# --- Optional: OAuth ---
# GOOGLE_CLIENT_ID="your_google_client_id_here"
# GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
# LINKEDIN_CLIENT_ID="your_linkedin_client_id_here"
# LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret_here"

# --- Optional: support widget ---
# NEXT_PUBLIC_CRISP_WEBSITE_ID=""

# --- Optional: analytics (PostHog) ---
# Leave unset to disable analytics entirely. The phc_ project key is a
# public client-side key by design; use your OWN project's key.
# NEXT_PUBLIC_POSTHOG_KEY="phc_your_posthog_project_key_here"
# NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# --- Optional: AI features ---
# ANTHROPIC_API_KEY="your_anthropic_api_key_here"
