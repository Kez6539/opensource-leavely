generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "cloudflare"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  country              String    @default("GB")
  // Per-tenant logo for the sidebar header. Stored inline as a base64
  // data URI (PNG/JPG/SVG, capped at ~80KB encoded so we don't bloat
  // every Tenant row read). When null the sidebar falls back to the
  // gradient "L" tile.
  logoDataUri          String?
  leaveYearStartMonth  Int       @default(4)
  clockInEnabled       Boolean   @default(false)
  onboardingStep       Int       @default(0)
  onboardedAt          DateTime?
  // Stamped when we've fired the founder's "new signup" notification.
  // Notification is intentionally deferred until the tenant proves
  // they're a real human (completes onboarding or enters card details)
  // to avoid burning founder attention on email-scanner prefetches and
  // abandoned sign-ups.
  signupNotifiedAt     DateTime?
  referredBy           String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  partner              Partner?  @relation(fields: [referredBy], references: [id])

  memberships    Membership[]
  employees      Employee[]
  leavePolicies  LeavePolicy[]
  leaveRequests  LeaveRequest[]
  leaveBalances  LeaveBalance[]
  publicHolidays PublicHoliday[]
  companyLeaves  CompanyLeave[]
  documents      Document[]
  auditLogs      AuditLog[]
  invites        Invite[]
  employeeNotes  EmployeeNote[]
  billing        TenantBilling?
  onboardingTemplates  OnboardingTemplate[]
  onboardingChecklists OnboardingChecklist[]
  announcements        Announcement[]
  notifications        Notification[]
  toilAccruals         ToilAccrual[]
  goals                Goal[]
  emergencyContacts    EmergencyContact[]
  expenseClaims        ExpenseClaim[]
  rotas                Rota[]
  shiftTemplates       ShiftTemplate[]
  clockEntries         ClockEntry[]
  locations            Location[]
  blackoutDates        BlackoutDate[]
  approvalDelegates    ApprovalDelegate[]
  reviewCycles         ReviewCycle[]
  reviews              Review[]
  pushSubscriptions    PushSubscription[]
  teams                Team[]
  courses              Course[]
  courseEnrollments     CourseEnrollment[]
  calendarTokens        CalendarToken[]
  commissions           Commission[]

  // Bank holiday deduction
  deductBankHolidays       Boolean @default(false)

  // Privacy & Permissions toggles
  hideEmployeeEmails       Boolean @default(false)
  hideEmployeeList         Boolean @default(false)
  preventLeaveCancellation Boolean @default(false)
  showWorkingStatus        Boolean @default(true)

  // Notification settings (tenant-level)
  notifyProbationEnding    Boolean @default(true)
  notifyProbationDays      Int     @default(14) // days before probation end
  notifyWorkAnniversaries  Boolean @default(true)
  notifyBirthdays          Boolean @default(true)
  notifyDocumentExpiry     Boolean @default(false)
  notifyDocumentExpiryDays Int     @default(30) // days before expiry

  // Clock-in settings
  clockInRequireLocation  Boolean @default(false)
  clockInAutoClockOut     Boolean @default(false)
  clockInAutoClockOutTime String? // "18:00"
  clockInMinBreak         Int     @default(0)
  clockInAllowManualEntry Boolean @default(true)
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
  LINKEDIN
  MICROSOFT
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String?
  authProvider AuthProvider  @default(CREDENTIALS)
  providerId   String?
  isSuperAdmin     Boolean      @default(false)
  emailPreferences Json         @default("{}")
  // Bumped on every password reset / forced logout. requireUser() compares
  // the value stamped into the session at login time and rejects sessions
  // that pre-date the change. Without this, an iron-session cookie issued
  // before a password reset is still valid until cookie expiry. (#171)
  passwordChangedAt DateTime?
  // Stamped on every successful login so super admin can see who's
  // active. Nullable for users who haven't logged in since the column
  // was added.
  lastLoginAt       DateTime?
  // When non-null the account is disabled — login is blocked and any
  // existing session is invalidated by requireUser(). Set by super
  // admins to off-board leavers without deleting historical records.
  disabledAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships       Membership[]
  passwordResets    PasswordReset[]
  magicLinks        MagicLink[]
  notifications     Notification[]
  courseEnrollments CourseEnrollment[]
  calendarTokens    CalendarToken[]

  @@unique([authProvider, providerId])
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
}

model Membership {
  id        String   @id @default(cuid())
  role      Role     @default(EMPLOYEE)
  tenantId  String
  userId    String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

// Where someone is physically working today. Stored as a Postgres enum so
// the case-mixing in the legacy free-form column ("Office", "remote",
// "REMOTE") can no longer happen — the DB rejects values outside this set.
// (#145)
enum WorkingStatus {
  office
  home
  hybrid
  away
  sick
  leave
}

// How an employee is paid. (#145)
enum SalaryFrequency {
  annual
  monthly
  weekly
  hourly
}

model Employee {
  id                    String         @id @default(cuid())
  firstName             String
  lastName              String
  email                 String?
  jobTitle              String?
  department            String?
  startDate             DateTime?
  dateOfBirth           DateTime?
  phone                 String?
  address               String?
  emergencyContactName  String?
  emergencyContactPhone String?
  hoursPerDay           Float?
  leaveYearStartMonth   Int?
  status                EmployeeStatus @default(ACTIVE)
  tenantId              String
  userId                String?
  managerId             String?
  salary                Decimal?
  salaryFrequency       SalaryFrequency?
  bankName              String?
  bankAccountNumber     String?
  bankSortCode          String?
  payrollNumber         String?
  pensionProvider       String?
  pensionNumber         String?
  taxCode               String?
  niNumber              String?
  contractType          String?
  noticePeriod          String?
  probationEndDate      DateTime?
  workingLocation       String?
  workingStatus         WorkingStatus? @default(office)
  gender                String?
  ethnicity             String?
  title                 String?
  middleName            String?
  homePhone             String?
  workPhone             String?
  workExtension         String?
  personalEmail         String?
  covidVaccinated       String?        @default("Not Specified")
  medicalNotes          String?
  terminationDate       DateTime?
  terminationReason     String?
  exitInterview         Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager        Employee?       @relation("ManagerReports", fields: [managerId], references: [id])
  reports        Employee[]      @relation("ManagerReports")
  leaveRequests        LeaveRequest[]
  leaveBalances        LeaveBalance[]
  notes                EmployeeNote[]
  onboardingChecklists OnboardingChecklist[]
  workingPattern       WorkingTimePattern[]
  toilAccruals         ToilAccrual[]
  goals                Goal[]
  emergencyContacts    EmergencyContact[]
  documents            Document[]
  expenseClaims        ExpenseClaim[]
  rotaEntries          RotaEntry[]
  clockEntries         ClockEntry[]
  delegatesAsManager   ApprovalDelegate[] @relation("DelegateManager")
  delegatesAsActor     ApprovalDelegate[] @relation("DelegateActor")
  reviews              Review[]           @relation("ReviewEmployee")
  reviewedReviews      Review[]           @relation("ReviewReviewer")
  teamMemberships      TeamMember[]
  managedTeams         Team[]             @relation("TeamManager")

  @@index([tenantId])
}

model LeavePolicy {
  id                    String   @id @default(cuid())
  name                  String
  unit                  String   @default("days")
  allowHalfDay          Boolean  @default(false)
  defaultAllowance      Int      @default(25)
  maxCarryoverDays      Int      @default(0)
  carryoverExpiryMonths Int?
  minNoticeDays         Int      @default(0)         // minimum days notice required (0 = no minimum)
  accrualType           String   @default("upfront")  // "upfront" or "monthly"
  serviceBonusDays      Json?                          // e.g. [{"years":2,"days":1},{"years":5,"days":3}]
  isSystemType          String?  // "lateness", "sickness", null
  tenantId              String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]
  companyLeaves CompanyLeave[]

  @@index([tenantId])
}

model LeaveBalance {
  id         String @id @default(cuid())
  employeeId String
  policyId   String
  tenantId   String
  year       Int
  allowance  Float
  used          Float  @default(0)
  pending       Float  @default(0)
  carryoverDays Float  @default(0)

  employee Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy   LeavePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([employeeId, policyId, year])
  @@index([tenantId])
}

model PublicHoliday {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  country   String   @default("GB")
  tenantId  String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model CompanyLeave {
  id                  String   @id @default(cuid())
  name                String
  startDate           DateTime
  endDate             DateTime
  // When true, on create we generate APPROVED LeaveRequest rows for every
  // active employee and deduct the days from their balance. On delete we
  // reverse it. Existing rows pre-migration are left at `false` (legacy
  // calendar-only behaviour).
  deductFromAllowance Boolean  @default(false)
  // Which policy to deduct from. Required when deductFromAllowance=true.
  policyId            String?
  tenantId            String
  createdAt           DateTime @default(now())

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  policy         LeavePolicy?   @relation(fields: [policyId], references: [id], onDelete: SetNull)
  leaveRequests  LeaveRequest[]

  @@index([tenantId])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id             String      @id @default(cuid())
  startDate      DateTime
  endDate        DateTime
  halfDayStart   Boolean     @default(false)
  halfDayEnd     Boolean     @default(false)
  reason         String?
  status         LeaveStatus @default(PENDING)
  decidedBy      String?
  decidedAt      DateTime?
  declineReason  String?
  reportedById   String?
  fitNoteRequired Boolean    @default(false)
  fitNoteUrl     String?
  latenessDuration String?   // e.g. "15 minutes", "30 minutes", "1 hour"
  // Timestamp of the most recent approval-reminder email sent for this
  // request. The cron uses this to dedupe so a retried run doesn't spam
  // managers with the same reminder every 5 minutes. NULL means never
  // reminded.
  lastReminderSentAt DateTime?
  tenantId       String
  employeeId     String
  policyId       String
  // Set when this LeaveRequest was auto-generated from a CompanyLeave
  // closure (mandatory shutdown). Lets the cleanup path on
  // deleteCompanyLeave find and reverse only the auto-generated rows.
  companyLeaveId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy        LeavePolicy      @relation(fields: [policyId], references: [id], onDelete: Cascade)
  companyLeave  CompanyLeave?    @relation(fields: [companyLeaveId], references: [id], onDelete: SetNull)
  returnToWork  ReturnToWork?

  @@index([tenantId])
  @@index([employeeId])
  @@index([companyLeaveId])
  // Composite indexes added after sweep 3 perf audit. Most leave queries
  // filter by (tenantId, status) and the dashboard "off today" / "upcoming"
  // queries also filter by date range.
  @@index([tenantId, status])
  @@index([tenantId, status, startDate, endDate])
}

model Document {
  id         String   @id @default(cuid())
  name       String
  category   String?
  filePath   String
  mimeType   String?
  size       Int?
  tenantId   String
  employeeId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  userId    String?
  tenantId  String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdAt])
}

model Invite {
  id        String    @id @default(cuid())
  email     String
  role      Role      @default(EMPLOYEE)
  token     String    @unique
  usedAt    DateTime?
  expiresAt DateTime?
  tenantId  String
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email], name: "one_invite_per_email")
  @@index([tenantId])
}

enum BillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model PasswordReset {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Passwordless sign-in / signup. Used by the /try funnel and future
// "email me a link" login flow — the token is sent via email and, on
// click, creates a session for the linked user.
model MagicLink {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TenantBilling {
  id                 String        @id @default(cuid())
  stripeCustomerId   String?
  stripeSubId        String?
  status             BillingStatus @default(TRIALING)
  planKey            String?
  currentPeriodEnd   DateTime?
  trialEndsAt        DateTime?
  lastTrialWarningAt DateTime?
  tenantId           String        @unique
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

/// Idempotency ledger for Stripe webhook events. Insert `event.id` at the top
/// of the handler inside a try/catch — a P2002 unique violation means Stripe
/// already delivered this event and we should return 200 without re-processing.
/// Prevents double-applied state + duplicate audit rows on Stripe retries.
model ProcessedStripeEvent {
  eventId     String   @id
  processedAt DateTime @default(now())

  @@index([processedAt])
}

enum OnboardingAssignTo {
  HR
  MANAGER
  EMPLOYEE
  IT
}

model OnboardingTemplate {
  id        String   @id @default(cuid())
  name      String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items      OnboardingTemplateItem[]
  checklists OnboardingChecklist[]

  @@index([tenantId])
}

model OnboardingTemplateItem {
  id          String             @id @default(cuid())
  templateId  String
  title       String
  description String?
  assignTo    OnboardingAssignTo @default(HR)
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())

  template OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model OnboardingChecklist {
  id          String   @id @default(cuid())
  employeeId  String
  templateId  String?
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  template OnboardingTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks    OnboardingTask[]

  @@index([tenantId])
  @@index([employeeId])
}

model OnboardingTask {
  id            String             @id @default(cuid())
  checklistId   String
  title         String
  description   String?
  assignTo      OnboardingAssignTo @default(HR)
  completedAt   DateTime?
  completedBy   String?
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now())

  checklist OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  publishedAt DateTime?
  expiresAt   DateTime?
  authorId    String
  tenantId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model EmployeeNote {
  id         String   @id @default(cuid())
  content    String
  employeeId String
  authorId   String
  tenantId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([tenantId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([tenantId])
}

model WorkingTimePattern {
  id           String  @id @default(cuid())
  employeeId   String
  dayOfWeek    Int     // 0=Sunday, 1=Monday, ..., 6=Saturday
  isWorkingDay Boolean @default(true)
  startTime    String? // "09:00"
  endTime      String? // "17:00"
  hoursPerDay  Float?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayOfWeek])
  @@index([employeeId])
}

model ReturnToWork {
  id             String   @id @default(cuid())
  leaveRequestId String   @unique
  notes          String?
  conductedById  String?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
}

model ToilAccrual {
  id          String   @id @default(cuid())
  employeeId  String
  tenantId    String
  date        DateTime
  hours       Float
  reason      String?
  status      ToilStatus @default(PENDING)
  approvedById String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([tenantId])
}

enum ToilStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_TRACK
  OVERDUE
  COMPLETED
  MISSED
}

model Goal {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      GoalStatus @default(NOT_STARTED)
  progress    Int        @default(0) // 0-100
  dueDate     DateTime?
  assigneeId  String
  createdById String
  tenantId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  assignee  Employee     @relation(fields: [assigneeId], references: [id], onDelete: Cascade)
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updates   GoalUpdate[]

  @@index([tenantId])
  @@index([assigneeId])
}

model GoalUpdate {
  id        String   @id @default(cuid())
  goalId    String
  note      String?
  progress  Int      // snapshot of progress at time of update
  userId    String
  createdAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

model EmergencyContact {
  id           String   @id @default(cuid())
  name         String
  relationship String
  phone        String
  email        String?
  isPrimary    Boolean  @default(false)
  employeeId   String
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([tenantId])
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum ExpenseCategory {
  TRAVEL
  MEALS
  EQUIPMENT
  ACCOMMODATION
  TRAINING
  OTHER
}

model ExpenseClaim {
  id              String          @id @default(cuid())
  description     String
  amount          Decimal         @db.Decimal(10, 2)
  currency        String          @default("GBP")
  category        ExpenseCategory
  date            DateTime
  status          ExpenseStatus   @default(PENDING)
  receiptUrl      String?
  receiptData     String?         // base64 encoded file
  receiptFilename String?         // original filename
  receiptMimeType String?         // e.g. image/jpeg, application/pdf
  notes           String?
  employeeId      String
  approvedById    String?
  approvedAt      DateTime?
  tenantId        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
}

enum RotaStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Rota {
  id        String     @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  status    RotaStatus @default(DRAFT)
  tenantId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entries RotaEntry[]

  @@index([tenantId])
  @@index([status])
}

model ShiftTemplate {
  id        String   @id @default(cuid())
  name      String
  startTime String   // "09:00"
  endTime   String   // "17:00"
  color     String   @default("#6366f1")
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entries RotaEntry[]

  @@index([tenantId])
}

model RotaEntry {
  id              String   @id @default(cuid())
  rotaId          String
  employeeId      String
  shiftTemplateId String?
  date            DateTime
  startTime       String?  // override: "09:00"
  endTime         String?  // override: "17:00"
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rota          Rota           @relation(fields: [rotaId], references: [id], onDelete: Cascade)
  employee      Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftTemplate ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id], onDelete: SetNull)

  @@index([rotaId])
  @@index([employeeId])
  @@index([date])
}

model ClockEntry {
  id           String    @id @default(cuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         DateTime
  clockIn      DateTime
  clockOut     DateTime?
  breakMinutes Int       @default(0)
  notes        String?
  totalHours   Decimal?
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  clockInLat   Decimal?
  clockInLng   Decimal?
  clockOutLat  Decimal?
  clockOutLng  Decimal?
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([tenantId])
  @@index([date])
}

model Location {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  latitude  Decimal?
  longitude Decimal?
  qrToken   String   @unique @default(cuid())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clockEntries ClockEntry[]

  @@index([tenantId])
}

model Partner {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  company         String?
  phone           String?
  referralCode    String    @unique
  commissionRate  Float     @default(0.4) // 40%
  status          String    @default("active") // active, paused, suspended
  userId          String?   // optional link to User for login
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  referrals       Tenant[]
  commissions     Commission[]

  @@index([referralCode])
}

model Commission {
  id          String   @id @default(cuid())
  partnerId   String
  tenantId    String
  // (#142) Money is Decimal, not Float. IEEE-754 doubles drift on simple
  // multiplications (£8.10 × 3 = £24.299999...) and affiliate payouts
  // stop reconciling against Stripe. Downstream callers wrap reads with
  // Number() so totals across many commissions remain plain JS numbers.
  amount      Decimal  @db.Decimal(10, 2)
  revenue     Decimal  @db.Decimal(10, 2)
  period      String   // e.g. "2026-03" (year-month)
  status      String   @default("pending") // pending, paid
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  partner     Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([partnerId, tenantId, period])
  @@index([partnerId])
  @@index([tenantId])
  @@index([status])
}

model BlackoutDate {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  tenantId  String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ApprovalDelegate {
  id          String   @id @default(cuid())
  managerId   String   // employee ID of the manager
  delegateId  String   // employee ID of the delegate
  startDate   DateTime
  endDate     DateTime
  tenantId    String
  createdAt   DateTime @default(now())

  manager  Employee @relation("DelegateManager", fields: [managerId], references: [id], onDelete: Cascade)
  delegate Employee @relation("DelegateActor", fields: [delegateId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([managerId])
  @@index([delegateId])
}

model CalendarToken {
  id            String    @id @default(cuid())
  token         String    @unique @default(cuid())
  userId        String
  tenantId      String
  scope         String    @default("personal") // "personal" or "team"
  // Updated by the /api/calendar/[token] feed endpoint each time a calendar
  // app pulls the ICS — gives admins visibility that the subscription is
  // actually being used.
  lastFetchedAt DateTime?
  createdAt     DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model SignupLead {
  id          String    @id @default(cuid())
  email       String
  name        String?
  company     String?
  source      String    @default("register")
  industry    String?
  convertedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([email])
  @@index([createdAt])
}

model ReviewCycle {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  status    String   @default("draft") // draft, active, completed
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@index([tenantId])
}

model Review {
  id            String    @id @default(cuid())
  cycleId       String
  employeeId    String
  // reviewerId is nullable so that historical reviews are retained when the
  // reviewer Employee is deleted (audit trail). UI should render "Unknown
  // reviewer" when null.
  reviewerId    String?
  status        String    @default("pending") // pending, in_progress, completed
  overallRating Int?
  strengths     String?
  improvements  String?
  notes         String?
  completedAt   DateTime?
  tenantId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cycle    ReviewCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employee Employee    @relation("ReviewEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer Employee?   @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([cycleId, employeeId])
  @@index([tenantId])
  @@index([cycleId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  tenantId  String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
  @@index([tenantId])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  managerId String?
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  manager Employee?    @relation("TeamManager", fields: [managerId], references: [id], onDelete: SetNull)
  members TeamMember[]
  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TeamMember {
  id         String   @id @default(cuid())
  teamId     String
  employeeId String
  createdAt  DateTime @default(now())

  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([teamId, employeeId])
  @@index([teamId])
  @@index([employeeId])
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   // "compliance", "wellbeing", "skills", "onboarding"
  duration    Int      // estimated minutes
  modules     CourseModule[]
  enrollments CourseEnrollment[]
  tenantId    String?  // null = system-wide (available to all tenants)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model CourseModule {
  id        String @id @default(cuid())
  courseId   String
  title     String
  content   String // rich text/markdown content
  sortOrder Int    @default(0)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model CourseEnrollment {
  id            String    @id @default(cuid())
  courseId       String
  userId        String
  tenantId      String
  progress      Int       @default(0) // modules completed count
  totalModules  Int
  completedAt   DateTime?
  lastModuleId  String?   // last module they were on
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId, tenantId])
  @@index([userId])
  @@index([tenantId])
}

// Persistent rate limit bucket. The previous in-memory `Map` rate limiter
// was useless on Cloudflare Workers — every isolate had its own map, so
// requests routed to fresh isolates always saw `count === 1` and the
// '5 per 60s' guard never fired. This table is the minimum-viable shared
// counter: one row per (key, windowStart) bucket, incremented atomically.
// A nightly cron sweeps rows older than 1 hour. (#172)
model RateLimitBucket {
  key         String
  windowStart DateTime
  count       Int      @default(1)
  updatedAt   DateTime @updatedAt

  @@id([key, windowStart])
  @@index([windowStart])
}

model DemoLead {
  id              String   @id @default(cuid())
  name            String
  company         String
  email           String
  phone           String
  employeeCount   String
  currentSystem   String?
  industry        String?
  painPoint       String
  painPointOther  String?
  createdAt       DateTime @default(now())
}

// Inbound messages from the public /contact form. Persisted so a Resend
// outage can't silently lose a warm lead.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  message   String
  createdAt DateTime @default(now())
}
