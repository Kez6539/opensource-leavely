# Cloudflare Workers Assets headers
#
# Hashed Next build artefacts and bundled fonts are immutable — every
# rebuild changes the filename. Without this, OpenNext was emitting
# `Cache-Control: public, max-age=0, must-revalidate` for /_next/static/*
# which forced a revalidation on every navigation (audit 2026-05-21).

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/_next/image/*
  Cache-Control: public, max-age=86400

/icons/*
  Cache-Control: public, max-age=31536000, immutable

/logo*
  Cache-Control: public, max-age=2592000

/favicon.ico
  Cache-Control: public, max-age=86400

/manifest.json
  Cache-Control: public, max-age=86400
